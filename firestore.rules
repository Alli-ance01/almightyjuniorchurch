rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if the user is signed in
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Function to check if the user is an admin
    // This requires a read to the users collection
    function isAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users Collection
    match /users/{userId} {
      // Anyone can create an account (handled during registration)
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Users can read/update their own profile, Admins can read/update all
      allow read, update: if (isAuthenticated() && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Announcements & Sermons
    match /announcements/{document=**} {
      // Anyone can read public content
      allow read: if true;
      // Only admins can modify
      allow write: if isAdmin();
    }
    
    match /sermons/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Contact Messages
    match /contactMessages/{document=**} {
      // Anyone can submit a contact message
      allow create: if true;
      // Only admins can read, update, or delete
      allow read, update, delete: if isAdmin();
    }

    // Prayer Requests
    match /prayerRequests/{document=**} {
      // Anyone can submit a prayer request
      allow create: if true;
      // Only admins can read, update, or delete
      allow read, update, delete: if isAdmin();
    }

    // Attendance
    match /attendance/{document=**} {
      // Users can read their own attendance and create new attendance records
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Only admins can update or delete
      allow update, delete: if isAdmin();
    }
  }
}
